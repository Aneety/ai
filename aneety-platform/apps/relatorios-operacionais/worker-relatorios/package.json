{
  "name": "@aneety/worker-relatorios",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker para geração operacional de relatórios PDF Aneety.",
  "scripts": {
    "lint": "node --check src/index.js",
    "typecheck": "node --check src/index.js",
    "build": "node --check src/index.js && npm run deploy:validate",
    "test": "node --test tests/*.test.js",
    "deploy:validate": "node scripts/validate-deploy-contract.mjs",
    "publication:validate": "node scripts/validate-publication-evidence.mjs",
    "smoke:published": "node scripts/smoke-pdf.mjs"
  }
}
